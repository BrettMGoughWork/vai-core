  },
  {
    "name": "no_internal_metadata_in_failure_response",
    "input": {
      "url": "https://blocked.example.com",
      "domain_policy": { "blocked.example.com": { "deny": true } }
    },
    "expected_output": {
      "forbidden_fields": ["mode", "signals", "fallback_history", "policy", "search_provider", "hydration", "internal", "stack"]
    },
    "purpose": "Failure response contains zero internal metadata fields"
  },
  {
    "name": "schema_stable_on_multiple_invocations",
    "input": {
      "url": "https://example.com",
      "executor": "immediate_success",
      "iterations": 10
    },
    "expected_output": {
      "schema_keys": ["ok", "status_code", "final_url", "headers", "cookies", "body", "elapsed_ms", "error_type", "error_message"],
      "invariant": "all responses have identical keys"
    },
    "purpose": "The public FetchResponse schema is stable and deterministic across repeated calls"
  }
