  {
    "name": "signal_redirect_loop_hard_escalation",
    "input": {
      "url": "https://example.com",
      "signals": { "redirect_loop": true },
      "current_mode": "http_simple",
      "response": { "ok": false, "error_type": "RedirectLoopError" }
    },
    "expected_output": {
