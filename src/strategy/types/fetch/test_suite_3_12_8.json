        "current_mode": "http_stealth",
        "error": { "error_type": "SSLError", "error_message": "certificate verification failed" }
      }
    },
    "expected_output": {
      "next_mode": "search",
      "timeout_seconds": 10
    },
    "purpose": "SSLError in stealth mode escalates to search"
  },
  {
