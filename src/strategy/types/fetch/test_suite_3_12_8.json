  },
  {
    "name": "domain_policy_deny_immediate_give_up",
    "input": {
      "url": "https://blocked.example.com",
      "domain_policy": { "blocked.example.com": { "deny": true } }
    },
    "expected_output": {
      "ok": false,
      "error_type": "Blocked"
    },
    "purpose": "Denied domain returns immediate failure without any fetch attempt"
  },
  {
    "name": "domain_policy_allow_false_immediate_give_up",
    "input": {
      "url": "https://restricted.example.com",
      "domain_policy": { "restricted.example.com": { "allow": false } }
    },
    "expected_output": {
      "ok": false,
      "error_type": "Blocked"
    },
    "purpose": "allow=false is treated as denied and returns immediate failure"
  },
  {
    "name": "domain_policy_preferred_mode_overrides_heuristics",
    "input": {
      "url": "https://example.com",
      "domain_policy": { "example.com": { "preferred_mode": "http_stealth" } }
    },
    "expected_output": {
      "ok": true,
      "status_code": 200
    },
    "purpose": "Preferred mode is used as initial mode regardless of heuristics"
  },
  {
    "name": "domain_policy_forbidden_mode_skipped_during_escalation",
    "input": {
      "url": "https://example.com",
      "domain_policy": { "example.com": { "forbidden_modes": ["http_hardened"] } }
    },
    "expected_output": {
      "ok": true
    },
    "purpose": "Forbidden mode is skipped; escalation jumps over it to the next available mode"
  },
  {
    "name": "domain_policy_rate_limit_delay_enforced",
    "input": {
      "url": "https://example.com",
      "domain_policy": { "example.com": { "rate_limit_ms": 500 } }
    },
    "expected_output": {
      "elapsed_ms": { "min": 500 }
    },
    "purpose": "Rate limit delay is enforced between successive fetch attempts"
  },
  {
    "name": "hydration_preserves_cookies_across_attempts",
    "input": {
      "url": "https://example.com",
      "first_response_cookies": { "session": "abc123", "csrf": "token1" }
    },
    "expected_output": {
      "second_request_cookies_contain": { "session": "abc123", "csrf": "token1" }
    },
    "purpose": "Cookies from a failed response are carried forward to the next request"
  },
  {
    "name": "hydration_preserves_headers_across_attempts",
    "input": {
      "url": "https://example.com",
      "initial_headers": { "authorization": "Bearer token1", "user-agent": "test/1.0" }
    },
    "expected_output": {
      "second_request_headers_contain": { "authorization": "Bearer token1" }
    },
    "purpose": "Headers from the initial request are preserved in subsequent attempts"
  },
  {
    "name": "hydration_updates_url_on_redirect",
    "input": {
      "url": "https://example.com/start",
      "response_url": "https://example.com/redirected"
    },
    "expected_output": {
      "next_request_url": "https://example.com/redirected"
    },
    "purpose": "The response URL is used for the next request when it differs from the original"
  },
  {
    "name": "hydration_merges_new_cookies_with_existing",
    "input": {
      "url": "https://example.com",
      "initial_cookies": { "tracking": "old" },
      "response_cookies": { "session": "new" }
    },
    "expected_output": {
      "second_request_cookies_contain": { "tracking": "old", "session": "new" }
    },
    "purpose": "New cookies from a response are merged with existing request cookies"
  },
  {
    "name": "hydration_no_internal_metadata_in_request",
    "input": {
      "url": "https://example.com",
      "response_with_internal": {
        "ok": false,
        "internal": { "mode": "http_simple", "signals": { "js_required": true }, "fallback_history": ["simple->hardened"] }
      }
    },
    "expected_output": {
      "next_request_fields": ["url", "method", "headers", "cookies", "timeout", "body"]
    },
    "purpose": "Hydrated request contains only public fields with no internal metadata"
  },
  {
    "name": "sanitisation_success_never_exposes_modes",
    "input": {
      "raw_response": {
        "ok": true,
        "status_code": 200,
        "final_url": "https://example.com",
        "headers": { "content-type": "text/html" },
        "cookies": {},
        "body": "<html>hello</html>",
        "elapsed_ms": 150,
        "internal": {
          "mode": "http_simple",
          "signals": {},
          "fallback_history": [],
          "policy": { "domain": "example.com", "allow": true }
        }
      }
    },
    "expected_output": {
      "ok": true,
      "status_code": 200,
      "final_url": "https://example.com",
      "headers": { "content-type": "text/html" },
      "cookies": {},
      "body": "<html>hello</html>",
      "elapsed_ms": 150
    },
    "purpose": "Success response never exposes internal mode, signals, or policy fields"
  },
  {
    "name": "sanitisation_failure_never_exposes_signals",
    "input": {
      "raw_response": {
        "ok": false,
        "elapsed_ms": 500,
        "internal": {
          "mode": "http_stealth",
          "error_type": "CloudflareBlockError",
          "error_message": "blocked by cloudflare_challenge after http_stealth attempt",
          "signals": { "cloudflare_challenge": true, "captcha_present": true },
          "fallback_history": ["http_simple", "http_hardened", "http_headless_browser", "http_stealth"],
          "policy": { "domain": "protected.example.com", "preferred_mode": "http_stealth" },
          "search_provider": null,
          "stack": "File 'fetch.py', line 42, in execute..."
        }
      }
    },
    "expected_output": {
      "ok": false,
      "error_type": "Blocked",
      "error_message": "The request was blocked by the target site.",
      "elapsed_ms": 500
    },
    "purpose": "Failure response sanitizes internal error details into public-safe categories"
  },
  {
    "name": "sanitisation_never_exposes_fallback_history",
    "input": {
      "raw_response": {
        "ok": false,
        "elapsed_ms": 1200,
        "internal": {
          "error_type": "FetchExhaustedError",
          "error_message": "escalation chain exhausted: http_simple→http_hardened→http_headless_browser→http_stealth→search→give_up",
          "fallback_history": [
            { "from": "http_simple", "to": "http_hardened", "reason": "NetworkError" },
            { "from": "http_hardened", "to": "http_headless_browser", "reason": "signal: js_required" },
            { "from": "http_headless_browser", "to": "http_stealth", "reason": "signal: cloudflare_challenge" },
            { "from": "http_stealth", "to": "search", "reason": "TimeoutError" },
            { "from": "search", "to": "give_up", "reason": "no results" }
          ]
        }
      }
    },
    "expected_output": {
      "ok": false,
      "error_type": "UnknownError",
      "error_message": "An unexpected error occurred while fetching the URL."
    },
    "purpose": "Exhaustion response never exposes fallback history or escalation chain"
  },
  {
    "name": "sanitisation_never_exposes_search_provider",
    "input": {
      "raw_response": {
        "ok": true,
        "status_code": 200,
        "final_url": "https://example.com",
        "headers": {},
        "cookies": {},
        "body": "search result page",
        "elapsed_ms": 200,
        "internal": {
          "mode": "search",
          "search_provider": "tavily",
          "signals": {},
          "fallback_history": ["http_simple", "http_hardened", "http_headless_browser", "http_stealth", "search"]
        }
      }
    },
    "expected_output": {
      "ok": true,
      "status_code": 200,
      "final_url": "https://example.com",
      "body": "search result page"
    },
    "purpose": "Search provider name (tavily) is never exposed to the LLM"
  },
  {
    "name": "sanitisation_never_exposes_stack_traces",
    "input": {
      "raw_response": {
        "ok": false,
        "elapsed_ms": 100,
        "internal": {
          "error_type": "ConnectionError",
          "error_message": "Traceback (most recent call last):\n  File 'fetch.py', line 42, in execute\n    raise ConnectionError('refused')\nConnectionError: connection refused",
          "stack": "File 'fetch.py', line 42, in execute\n  File 'transport.py', line 15, in connect\nConnectionError"
        }
      }
    },
    "expected_output": {
      "ok": false,
      "error_type": "NetworkError"
    },
    "purpose": "Stack traces and file paths are never exposed in error messages"
  },
