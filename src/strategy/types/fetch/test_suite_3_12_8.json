        { "mode": "search", "ok": true, "body": "search result" }
      ]
    },
    "expected_output": {
      "ok": true,
      "body": "search result"
    },
    "purpose": "Search is invoked ONLY after simple, hardened, headless, and stealth all fail"
  },
  {
    "name": "search_failure_results_in_give_up",
    "input": {
      "url": "https://example.com",
      "executor_responses": [
        { "mode": "http_simple", "ok": false },
        { "mode": "http_hardened", "ok": false },
        { "mode": "http_headless_browser", "ok": false },
        { "mode": "http_stealth", "ok": false },
        { "mode": "search", "ok": false, "error_type": "TimeoutError" }
      ]
    },
    "expected_output": {
      "ok": false
    },
    "purpose": "When search also fails, the orchestrator gives up"
  },
  {
    "name": "search_success_returns_valid_response",
    "input": {
      "url": "https://example.com",
      "search_result": {
        "ok": true,
        "status_code": 200,
        "final_url": "https://example.com/cached",
        "headers": { "content-type": "text/html" },
        "cookies": {},
        "body": "<html>cached page</html>",
        "elapsed_ms": 250
      }
    },
    "expected_output": {
      "ok": true,
      "status_code": 200,
      "final_url": "https://example.com/cached",
      "body": "<html>cached page</html>",
      "elapsed_ms": 250
    },
    "purpose": "Successful search fallback returns a valid public FetchResponse"
  },
  {
    "name": "success_response_returns_ok_true_with_body",
    "input": {
      "url": "https://example.com",
      "executor": "immediate_success"
    },
    "expected_output": {
      "ok": true,
      "status_code": 200,
      "body": "<html>hello</html>"
    },
    "purpose": "Successful fetch returns ok=true, status code, and full body"
  },
  {
    "name": "failure_response_returns_ok_false_with_public_error",
    "input": {
      "url": "https://example.com",
      "executor": "always_fail"
    },
    "expected_output": {
      "ok": false,
      "error_type": "matches:NetworkError|Timeout|InvalidResponse|Blocked|UnknownError"
    },
    "purpose": "Failed fetch returns ok=false with a public-safe error_type only"
  },
  {
    "name": "elapsed_ms_present_and_numeric_on_success",
    "input": {
      "url": "https://example.com",
      "executor": "immediate_success"
    },
    "expected_output": {
      "ok": true,
      "elapsed_ms": { "type": "number", "min": 0 }
    },
    "purpose": "elapsed_ms is always present and is a non-negative integer"
  },
  {
    "name": "elapsed_ms_present_and_numeric_on_failure",
    "input": {
      "url": "https://example.com",
      "executor": "always_fail"
    },
    "expected_output": {
      "ok": false,
      "elapsed_ms": { "type": "number", "min": 0 }
    },
    "purpose": "elapsed_ms is present even when the fetch fails"
  },
  {
    "name": "headers_are_well_formed_dict",
    "input": {
      "url": "https://example.com",
      "executor": "returns_headers"
    },
    "expected_output": {
      "ok": true,
      "headers": { "content-type": "string", "content-length": "string" }
    },
    "purpose": "Response headers are a well-formed string-to-string dictionary"
  },
  {
    "name": "cookies_are_well_formed_dict",
    "input": {
      "url": "https://example.com",
      "executor": "returns_cookies"
    },
    "expected_output": {
      "ok": true,
      "cookies": { "session": "string" }
    },
    "purpose": "Response cookies are a well-formed string-to-string dictionary"
  },
  {
    "name": "no_internal_metadata_in_success_response",
    "input": {
      "url": "https://example.com",
      "executor": "immediate_success"
    },
    "expected_output": {
      "forbidden_fields": ["mode", "signals", "fallback_history", "policy", "search_provider", "hydration", "internal", "stack"]
    },
