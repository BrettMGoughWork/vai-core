[
  {
    "name": "escalation_simple_to_hardened_on_network_error",
    "input": {
      "url": "https://example.com",
      "fallback_input": {
        "current_mode": "http_simple",
        "error": { "error_type": "NetworkError", "error_message": "connection refused" }
      }
    },
    "expected_output": {
      "next_mode": "http_hardened",
      "timeout_seconds": 15
    },
    "purpose": "NetworkError in simple mode escalates to hardened"
  },
  {
    "name": "escalation_hardened_to_headless_on_timeout",
    "input": {
      "url": "https://example.com",
      "fallback_input": {
        "current_mode": "http_hardened",
        "error": { "error_type": "TimeoutError", "error_message": "request timed out after 15s" }
      }
    },
    "expected_output": {
      "next_mode": "http_headless_browser",
      "timeout_seconds": 30
    },
    "purpose": "TimeoutError in hardened mode escalates to headless"
  },
  {
    "name": "escalation_headless_to_stealth_on_dns_failure",
    "input": {
      "url": "https://example.com",
      "fallback_input": {
        "current_mode": "http_headless_browser",
        "error": { "error_type": "DNSFailure", "error_message": "name resolution failed" }
      }
    },
    "expected_output": {
      "next_mode": "http_stealth",
      "timeout_seconds": 45
    },
    "purpose": "DNSFailure in headless mode escalates to stealth"
  },
  {
    "name": "escalation_stealth_to_search_on_ssl_error",
    "input": {
      "url": "https://example.com",
