  {
    "name": "search_invoked_only_after_all_modes_exhausted",
    "input": {
      "url": "https://example.com",
      "executor_responses": [
        { "mode": "http_simple", "ok": false, "error_type": "HTTPError" },
        { "mode": "http_hardened", "ok": false, "error_type": "HTTPError" },
        { "mode": "http_headless_browser", "ok": false, "error_type": "HTTPError" },
