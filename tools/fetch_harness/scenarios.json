{
  "meta": {
    "description": "Fetch hardness test scenarios. Add sites here to define what kinds of websites you want to test against as fetch modes evolve.",
    "hardness_levels": {
      "simple": "Static HTML, no JS dependency - should work with basic HTTP fetch",
      "hardened": "Anti-bot detection, WAF, Cloudflare - may need hardened mode (3.11.1)",
      "javascript": "JS-rendered content needed - requires Playwright (3.11.2)",
      "spa": "Single-page app, full JS framework - requires Playwright (3.11.2)",
      "antibot": "Advanced bot detection, reCAPTCHA - requires stealth mode (3.11.3)"
    },
    "expected_keys": {
      "name": "Unique scenario name",
      "url": "Target URL",
      "hardness": "One of the hardness levels above",
      "description": "What this site tests",
      "tags": "Categorisation tags",
      "expect": "Optional: expected response characteristics",
      "expect.status_code": "Expected HTTP status (or range like 2xx, 4xx)",
      "expect.body_min_length": "Minimum body length in bytes",
      "expect.content_type_hint": "Expected content-type prefix (e.g. text/html)"
    }
  },
  "scenarios": [
    {
      "name": "example_com",
      "url": "https://example.com",
      "hardness": "simple",
      "description": "IANA example domain - static HTML, no JS, always up",
      "tags": ["static", "html", "canonical"],
      "expect": {
        "status_code": "200",
        "body_min_length": 100,
        "content_type_hint": "text/html"
      }
    },
    {
      "name": "httpbin_get",
      "url": "https://httpbin.org/get",
      "hardness": "simple",
      "description": "httpbin GET echo - returns JSON with request metadata",
      "tags": ["api", "json", "echo"],
      "expect": {
        "status_code": "200",
        "body_min_length": 50,
        "content_type_hint": "application/json"
      }
    },
    {
      "name": "httpbin_status_404",
      "url": "https://httpbin.org/status/404",
      "hardness": "simple",
      "description": "httpbin returns 404 - tests non-2xx handling",
      "tags": ["api", "error", "4xx"],
      "expect": {
        "status_code": "404",
        "body_min_length": 0
      }
    },
    {
      "name": "httpbin_status_500",
      "url": "https://httpbin.org/status/500",
      "hardness": "simple",
      "description": "httpbin returns 500 - tests 5xx handling",
      "tags": ["api", "error", "5xx"],
      "expect": {
        "status_code": "500",
        "body_min_length": 0
      }
    },
    {
      "name": "httpbin_delay",
      "url": "https://httpbin.org/delay/3",
